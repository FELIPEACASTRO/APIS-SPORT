# Configuração APIS // SPORT
# ─────────────────────────────────────────────────────────────────────────
# Copie este arquivo para `.env` e ajuste os valores antes de subir o servidor.
# O `.env` já está no .gitignore — sua chave nunca vai para o repositório.

# Porta HTTP do servidor (default: 3000)
PORT=3000

# Ambiente: production | development | test
NODE_ENV=production

# Chave do RapidAPI — obrigatória apenas para usar modo "real" com chave server-side.
# Em modo "mock" (default) este campo pode ficar vazio.
# Obtenha em https://rapidapi.com/developer/dashboard
RAPIDAPI_KEY=

# Token interno obrigatório para liberar chamadas em modo real quando REQUIRE_REAL_AUTH=true.
# Envie como header `X-Invoke-Token` ou `Authorization: Bearer <token>`.
REAL_INVOKE_TOKEN=
REQUIRE_REAL_AUTH=true

# Em produção, mantenha false para não aceitar chave RapidAPI enviada pelo browser/body.
ALLOW_CLIENT_RAPIDAPI_KEY=false

# Timeout das chamadas ao RapidAPI upstream (ms)
UPSTREAM_TIMEOUT_MS=10000

# Proteção opcional das métricas. Se preenchido, envie X-Metrics-Token ou Bearer token.
METRICS_TOKEN=

# CORS: use origins explícitos em produção, separados por vírgula.
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=false

# Nível de log:
#   - info (default): cada request é logado no stdout
#   - silent: apenas erros 5xx
LOG_LEVEL=info
LOG_FORMAT=pretty

# Amostra de chamadas reais no `npm run qa -- --real` (default: 3)
# Apenas usado se RAPIDAPI_KEY estiver definida.
QA_REAL_SAMPLE=3
